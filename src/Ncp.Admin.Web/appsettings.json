{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Database=test_oa;Username=postgres;Password=123456",
    "Redis": "localhost:6379"
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "Port": 5672
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5666",
      "http://localhost:5173",
      "http://192.168.30.45:8076",
      "http://192.168.30.45:8077",
      "http://localhost:3000"
    ]
  },
  "AppConfiguration": {
    "Secret": "your-secret-key-here",
    "TokenExpiryInMinutes": 1440,
    "JwtIssuer": "netcorepal",
    "JwtAudience": "netcorepal"
  },
  "FileStorage": {
    // 存储实现：Local = 本地磁盘，MinIO = MinIO 对象存储
    "Provider": "Local",
    "Local": {
      // 本地存储根目录（相对应用根路径或绝对路径）
      "RootPath": "uploads",
      // 是否通过静态文件中间件提供访问
      "ServeViaStaticFiles": false
    },
    "MinIO": {
      // MinIO 服务地址，不要带 http/https 前缀，如 localhost:9000
      "Endpoint": "",
      // MinIO 访问密钥（生产环境建议用环境变量或 User Secrets）
      "AccessKey": "",
      // MinIO 秘密密钥
      "SecretKey": "",
      // 存储桶名称，不存在时首次上传会自动创建
      "Bucket": "net-oa",
      // 是否使用 HTTPS
      "UseSSL": true
    }
  },
  "Services": {
    "user": {
      "https": [
        "https://user:8443"
      ]
    },
    "user-v2": {
      "https": [
        "https://user-v2:8443"
      ]
    }
  }
}
